{
  "name": "trust-electric-automation",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered lead generation and business automation for Trust Electric Heating Ltd",
  "workspaces": [
    "landing-page",
    "dashboard",
    "ai-content",
    "shared"
  ],
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "stop": "bash scripts/stop.sh",
    "landing": "npm run dev --workspace=landing-page",
