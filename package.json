    "build:landing": "npm run build --workspace=landing-page",
    "build:dashboard": "npm run build --workspace=dashboard",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
