# ============================================================
# Trust Electric Heating — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# Database
# PostgreSQL connection string.
# Local dev: matches docker-compose.yml defaults.
# Production: get from Railway/Render dashboard.
# ------------------------------------------------------------
DATABASE_URL=postgresql://trust:trust_dev_only@localhost:5432/trust_electric

# Redis connection string.
# Local dev: matches docker-compose.yml defaults.
REDIS_URL=redis://localhost:6379

# ------------------------------------------------------------
# Notifications — Twilio (SMS)
# Sign up at twilio.com — free trial gives you a test number.
# TWILIO_ACCOUNT_SID and TWILIO_AUTH_TOKEN are in the Console.
# TWILIO_PHONE_NUMBER is your Twilio number (E.164 format).
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+44xxxxxxxxxx

# ------------------------------------------------------------
# Notifications — Resend (Email)
# Sign up at resend.com — free tier allows 100 emails/day.
# Get API key from the Resend dashboard.
# ------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Business Owner Contact
# Where new lead notifications are sent.
# Replace with real sales team contact details.
# ------------------------------------------------------------
OWNER_PHONE=+44xxxxxxxxxx
OWNER_EMAIL=sales@trustelectricheating.co.uk

# ------------------------------------------------------------
# AI — Anthropic Claude
# Get API key from console.anthropic.com
# Used by the AI content generator (Automation 5).
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Xero Integration (Automation 6)
# Create an app at developer.xero.com to get these.
# Leave empty if using mock data.
# ------------------------------------------------------------
XERO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XERO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# Unleashed Integration (Automation 6)
# Get from your Unleashed account under Integrations > API.
# Leave empty if using mock data.
# ------------------------------------------------------------
UNLEASHED_API_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UNLEASHED_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to true to use mock data instead of real Xero/Unleashed.
# Always true in local dev unless you have real credentials.
USE_MOCK_DATA=true

# ------------------------------------------------------------
# Frontend URLs
# NEXT_PUBLIC_API_URL: used by the Next.js landing page.
# VITE_API_URL: used by the Vite dashboard.
# Change to production backend URL when deploying.
# ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# ------------------------------------------------------------
# Deployment
# Set by Vercel automatically. Leave empty locally.
# ------------------------------------------------------------
VERCEL_URL=
